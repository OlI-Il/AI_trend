# YouTube Data API v3 (optional — transcripts work without it, search needs it)
# Get your key at: https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gmail OAuth is handled separately:
#   1. Set up OAuth credentials at https://console.cloud.google.com/
#   2. Run: npx @shinzolabs/gmail-mcp auth
#   3. Credentials are stored at ~/.gmail-mcp/ (not in this repo)
