# YouTube Data API v3
# Get your key at: https://console.cloud.google.com/ → APIs & Services → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gmail (Optional — only needed for real email sending)
# Download credentials.json from Google Cloud Console → OAuth 2.0 Client IDs
# token.json is auto-generated after first OAuth flow — do not commit it
GMAIL_SENDER_EMAIL=your_email@gmail.com
