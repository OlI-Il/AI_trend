{
  "mcpServers": {
    "youtube": {
      "command": "node",
      "args": [
        "mcp/youtube/dist/index.js"
      ]
    },
    "notion": {
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "${NOTION_TOKEN}"
      }
    }
  }
}
