{
  "name": "youtube-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for YouTube Data API v3 integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/youtube-transcript/package.json',pkg=JSON.parse(fs.readFileSync(p));pkg.main='dist/youtube-transcript.esm.js';fs.writeFileSync(p,JSON.stringify(pkg,null,2))\"",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "axios": "^1.7.9",
    "dotenv": "^17.3.1",
    "youtube-transcript": "1.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
